    {
      "parameters": {
        "jsCode": "const now  = new Date();\nconst to   = now.toISOString().split('T')[0];\nconst from = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];\nreturn [{ json: { from, to } }];\n"
      },
