      "typeVersion": 2.3,
      "position": [
        750,
        300
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const triggerData = $('Bambuser Webhook Trigger').first().json;\nconst shopperId = triggerData.body?.shopperId ?? triggerData.shopperId ?? 'unknown';\nconst requestId = triggerData.body?.requestId ?? triggerData.requestId ?? 'unknown';\nconst deleteResult = $input.first().json;\nconst isoDate = new Date().toISOString();\nconst auditLine = `${isoDate} | Request: ${requestId} | Shopper: ${shopperId} | Status: success`;\nreturn [{ json: { auditLine, shopperId, requestId, status: 'success', deleteResult } }];\n",
        "mode": "runOnceForAllItems"
      },
      "id": "e5f6a7b8-c9d0-1234-efab-345678901234",
      "name": "Format Audit Log (Success)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        200
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const triggerData = $('Bambuser Webhook Trigger').first().json;\nconst shopperId = triggerData.body?.shopperId ?? triggerData.shopperId ?? 'unknown';\nconst requestId = triggerData.body?.requestId ?? triggerData.requestId ?? 'unknown';\nconst deleteResult = $input.first().json;\nconst isoDate = new Date().toISOString();\nconst auditLine = `${isoDate} | Request: ${requestId} | Shopper: ${shopperId} | Status: failed`;\nreturn [{ json: { auditLine, shopperId, requestId, status: 'failed', deleteResult } }];\n",
        "mode": "runOnceForAllItems"
      },
      "id": "f6a7b8c9-d0e1-2345-fabc-456789012345",
      "name": "Format Audit Log (Failed)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
