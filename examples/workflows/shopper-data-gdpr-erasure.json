            "typeValidation": "loose"
          },
          "combinator": "or",
          "conditions": [
            {
              "id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
              "operator": {
                "type": "number",
                "operation": "equals"
              },
              "leftValue": "={{ $json.statusCode }}",
              "rightValue": 200
            },
            {
              "id": "d4e5f6a7-b8c9-0123-defa-234567890123",
