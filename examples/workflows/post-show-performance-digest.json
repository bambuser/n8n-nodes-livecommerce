    {
      "parameters": {
        "jsCode": "const show  = ($('Get Show Details').first().json.data || {});\nconst stats = ($('Get Show Stats').first().json.data  || {});\nconst prods = (show.products || []).map(p => p.title).filter(Boolean).join(', ') || 'N/A';\nreturn [{\n  json: {\n    showTitle: show.title || 'Untitled',\n    prompt: `Write a concise post-show performance digest for a live shopping event.\n\nShow: \"${show.title || 'Untitled'}\"\nProducts Featured: ${prods}\n\nMetrics:\n• Views: ${stats.views ?? 0}\n• Unique Viewers: ${stats.uniqueViewers ?? 0}\n• Add-to-Cart Clicks: ${stats.addToCartClicks ?? 0}\n• Purchases: ${stats.purchases ?? 0}\n• Revenue: $${stats.revenue ?? 0}\n\nProvide 4 bullet-point highlights and 1 actionable recommendation.\nKeep it brief and data-driven. Plain text, no markdown headers.`\n  }\n}];\n"
      },
      "id": "efc47bc9-e0ac-4587-a808-2d681a18f97d",
      "name": "Build Stats Prompt",
