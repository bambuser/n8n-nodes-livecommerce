      "parameters": {
        "jsCode": "const digest = ($input.first().json.text || $input.first().json.output || '').trim();\nconst title  = $('Build Stats Prompt').first().json.showTitle;\nreturn [{ json: { text: `📊 *Post-show digest — ${title}*\\n\\n${digest}` } }];\n"
