    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst allVideos = response.data || [];\nconst video = allVideos.find(v => {\n  const details = v.videoDetails;\n  return !details || !details.length || !details[0]?.description;\n}) || allVideos[0];\nif (!video) return [];\nconst details = video.videoDetails?.[0] || {};\nconst title = details.title || video.filename || 'Untitled Show';\nreturn [{\n  json: {\n    videoId: video.id,\n    title,\n    prompt: `You are a content writer for a live shopping video platform.\n\nWrite an engaging description for a shoppable video titled \"${title}\".\nRequirements:\n- 2-3 sentences, max 280 characters\n- Highlight the live shopping experience\n- Encourage viewers to watch\nReturn ONLY the description text, nothing else.`\n  }\n}];"
      },
      "id": "15e02fc8-9013-4eb5-8635-98f899853e53",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        304
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.prompt }}",
        "batching": {}
      },
      "id": "aae2fae1-ad7f-4970-bff7-1f6c545df614",
      "name": "Generate Shoppable Video Metadata",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
