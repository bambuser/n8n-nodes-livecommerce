      },
      "id": "ec49a8c1-c1a2-43c4-bde2-f0723c60ab8d",
      "name": "Gemini \u2014 Generate Shoppable Video Metadata",
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1.1,
      "position": [
        856,
        528
      ],
      "credentials": {
        "googlePalmApi": {
          "id": "zWjTkBrecPDssM2x",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const ai = ($input.first().json.text || $input.first().json.output || '').trim();\nconst src = $('Build Prompt').first().json;\nreturn [{ json: { videoId: src.videoId, title: src.title, description: ai.slice(0, 280) } }];\n"
      },
      "id": "3ffbbf5c-5ddd-4586-bd8d-96f68e223175",
